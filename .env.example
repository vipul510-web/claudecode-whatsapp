# Get from https://gaviventures.com/whatsapp/settings/api-keys
GAVI_API_KEY=gv_your_key_here

# Set after running: npm run setup-webhook
WEBHOOK_SECRET=

# Public URL where this server is reachable (e.g. from ngrok or your server)
WEBHOOK_URL=https://your-domain-or-ngrok-url.com

# Absolute path to the project directory Claude should work in
WORK_DIR=/Users/vipulagarwal/Projects

# Max Claude Code turns per request (default: 10)
MAX_TURNS=10

# Port for the webhook server
PORT=3001
